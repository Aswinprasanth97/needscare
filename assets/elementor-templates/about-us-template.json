              "settings": {
                "editor": "<nav class=\"breadcrumbs\" aria-label=\"Breadcrumb\"><a href=\"/\"><i class=\"fa-solid fa-house\"></i> Home</a> <span class=\"breadcrumb-sep\" aria-hidden=\"true\">/</span> <span class=\"breadcrumb-current\">About Us</span></nav>",
