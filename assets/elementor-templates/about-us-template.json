            },
            {
              "id": "c1d2e3f4",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Needs Care provides personalised nursing and disability support services to help individuals live safely, independently, and with dignity.</p>",
                "text_color": "rgba(255,255,255,0.85)",
                "typography_typography": "custom",
                "typography_font_size": { "unit": "rem", "size": 1.12 },
