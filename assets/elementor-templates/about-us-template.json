              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Compassionate Nursing & Disability Support You Can Trust",
                "header_size": "h1",
                "title_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_family": "DM Serif Display",
                "typography_font_size": { "unit": "rem", "size": 3.2 },
