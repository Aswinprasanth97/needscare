          "elements": [
            {
              "id": "d0e1f2a3",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<h4 class=\"section-subtitle\"><i class=\"fa-solid fa-heart-pulse\"></i> Who We Are</h4>",
                "css_classes": "abt-intro-text"
              }
            },
            {
              "id": "b4c5d6e7",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "About Needs Care",
                "header_size": "h2",
                "css_classes": "section-title"
              }
            },
            {
              "id": "f8a9b0c1",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Needs Care is dedicated to providing compassionate and professional healthcare and disability support services. Our experienced nurses and support workers focus on improving the well-being, independence, and quality of life of every individual we support.</p><p>We believe everyone deserves respectful care, dignity, and the opportunity to live a fulfilling life. Our team works closely with participants and families to create personalised support plans tailored to their unique needs.</p>"
              }
            }
          ]
        },
        {
          "id": "d2e3f4a5",
          "elType": "column",
          "settings": { "_column_size": 50 },
          "elements": [
            {
              "id": "b6c7d8e9",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"abt-img-stack\"><div class=\"abt-img-main\"><img src=\"/wp-content/themes/needscare-theme/assets/images/indigenous-care-main.png\" alt=\"Nurse caring for indigenous Australian patient\" loading=\"lazy\" /></div><div class=\"abt-img-accent\"><img src=\"/wp-content/themes/needscare-theme/assets/images/indigenous-care-accent.png\" alt=\"Support worker assisting indigenous Australian\" loading=\"lazy\" /></div><div class=\"abt-img-badge\"><i class=\"fa-solid fa-shield-halved\"></i><span>NDIS<br>Registered</span></div></div>",
                "css_classes": "abt-intro-visual"
              }
            }
          ]
        }
      ]
    },

